{
    "mcpServers": {
        "google-drive": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-google-drive"
            ],
            "env": {
                "GOOGLE_DRIVE_FOLDER_ID": "REPLACE_WITH_FOLDER_ID"
            }
        },
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/opt/nexus_data/sync_inbox"
            ]
        },
        "puppeteer": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-puppeteer"
            ],
            "env": {
                "STEALTH_MODE": "true"
            }
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_PAT"
            }
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "memory": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ]
        },
        "brave-search": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-brave-search"
            ],
            "env": {
                "BRAVE_API_KEY": "REPLACE_WITH_KEY"
            }
        },
        "postgres": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-postgres"
            ],
            "env": {
                "POSTGRES_CONNECTION_STRING": "REPLACE_WITH_SUPABASE_URL"
            }
        }
    }
}