# === NEXUS ENVIRONMENT VARIABLES ===
# Copy this file to .env and set real values.
# Never commit .env or hardcode tokens in git remote URLs.

# Git
GIT_BACKUP_BRANCH=main
NEXUS_NODE_ID=pc-local

# GitHub CLI auth (session env recommended)
# GH_TOKEN=github_pat_xxx

# HuggingFace
HF_TOKEN=hf_xxxxx
HF_DATASET_REPO=israel-nexus/knowledge-base
HF_SYNC_DIR=knowledge

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJxxxx
SUPABASE_LOCK_TABLE=nexus_locks
SUPABASE_DLQ_TABLE=dead_letter_queue
# Optional backup marker table
SUPABASE_BACKUP_TABLE=nexus_backup_runs

# rclone (optional thesis sync)
RCLONE_REMOTE=drive:Tesis_NEXUS
RCLONE_SOURCE=thesis_chapters

# Nomad quota telemetry (optional but recommended)
CODESPACES_HOURS_LEFT=60
GITPOD_HOURS_LEFT=50
GCP_CREDIT_LEFT_USD=300
GITPOD_READY=0
ORACLE_NODE_READY=0
CLOUD_SHELL_READY=1

# Optional notifications
# NOMAD_WEBHOOK_URL=https://example.com/webhook

# Oracle Cloud
OCI_CONFIG_FILE=~/.oci/config

# Cloudflare
CF_TUNNEL_TOKEN=xxxxx
